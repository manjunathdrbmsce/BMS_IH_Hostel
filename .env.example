# =============================================================================
# BMS Hostel Platform - Environment Variables
# Copy to .env and fill in values. NEVER commit the .env file.
# =============================================================================

# --- App ---
NODE_ENV=development
APP_PORT=3001
APP_NAME=BMS Hostel API
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=bms_user
DB_PASSWORD=bms_secret_dev
DB_NAME=bms_hostel
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=bms_redis_dev

# --- JWT ---
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Rate Limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# --- File Storage (S3-compatible, phase-ready) ---
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=

# --- Payment Gateway (phase-ready) ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Email/SMS (phase-ready) ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMS_PROVIDER_API_KEY=

# --- Super Admin Seed ---
SEED_ADMIN_EMAIL=admin@bms.local
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_FIRST_NAME=Super
SEED_ADMIN_LAST_NAME=Admin
