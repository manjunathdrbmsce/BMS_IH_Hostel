{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "clean": "rimraf .expo dist android/app/build"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-splash-screen": "~31.0.13",
    "expo-linear-gradient": "~15.0.8",
    "expo-haptics": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-location": "~19.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-secure-store": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-application": "~7.0.8",
    "expo-constants": "~18.0.13",
    "@react-native-community/datetimepicker": "8.4.4",

    "dotenv": "^16.4.0",

    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "~15.12.1",
    "react-native-mmkv": "~3.3.3",
    "react-native-qrcode-svg": "~6.3.21",

    "@expo/vector-icons": "~15.1.1",
    "@tanstack/react-query": "~5.62.16",
    "axios": "~1.13.6",
    "date-fns": "~4.1.0",
    "zustand": "~5.0.11"
  },
  "devDependencies": {
    "expo-dev-client": "~6.0.20",
    "@types/react": "~19.1.17",
    "babel-plugin-module-resolver": "~5.0.2",
    "typescript": "~5.7.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "@testing-library/react-native": "~12.4.0",
    "rimraf": "~6.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|react-native-svg|react-native-mmkv|zustand|@tanstack|date-fns|axios)"
    ]
  }
}
