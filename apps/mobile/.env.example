# Mobile App Environment Variables
# Copy to .env and fill in values. NEVER commit the .env file.
#
# For local development:
#   - Android emulator: use 10.0.2.2 to reach host localhost
#   - iOS simulator / physical device: use your machine's LAN IP
#
# For production / staging, set the real API domain.

API_BASE_URL=http://localhost:3001

# Optional: Override for Android emulator (defaults to 10.0.2.2 if omitted)
# ANDROID_API_BASE_URL=http://10.0.2.2:3001
