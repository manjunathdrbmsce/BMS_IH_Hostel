// =============================================================================
// BMS Hostel Platform - Prisma Schema
// Phase 1: Identity, RBAC, Audit
// Phase 2: Hostel & Room Management
// Phase 3: Buildings, Policies, Student Profiles, Allotments
// Phase 4: Leave, Complaints, Notices, Gate Management
// Phase 5: Violations, Policy Snapshots, Notifications
// Phase 6: Student Registration / Hostel Admission
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & Authentication
// ---------------------------------------------------------------------------

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique @db.VarChar(255)
  mobile        String?    @unique @db.VarChar(20)
  usn           String?    @unique @db.VarChar(50) // University Seat Number
  passwordHash  String     @map("password_hash") @db.VarChar(255)
  firstName     String     @map("first_name") @db.VarChar(100)
  lastName      String     @map("last_name") @db.VarChar(100)
  status        UserStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("AuditUser")
  beds          Bed[]          @relation("BedStudent")

  // Phase 3 relations
  studentProfile    StudentProfile?
  guardianLinks     GuardianLink[]     @relation("GuardianUser")
  wardGuardianLinks GuardianLink[]     @relation("WardUser")
  bedAssignments    BedAssignment[]    @relation("AssignmentStudent")
  assignedBy        BedAssignment[]    @relation("AssignmentAssignedBy")

  // Phase 4 relations
  leaveRequests        LeaveRequest[]      @relation("LeaveStudent")
  leaveWardenApprovals LeaveRequest[]      @relation("LeaveWarden")
  leaveParentActions   LeaveRequest[]      @relation("LeaveParent")
  complaints           Complaint[]         @relation("ComplaintStudent")
  complaintsAssigned   Complaint[]         @relation("ComplaintAssignedTo")
  complaintComments    ComplaintComment[]
  noticesPublished     Notice[]            @relation("NoticePublisher")
  noticeRecipients     NoticeRecipient[]
  gateEntries          GateEntry[]         @relation("GateStudent")
  gateScans            GateEntry[]         @relation("GateScanner")
  gatePasses           GatePass[]          @relation("GatePassStudent")
  gatePassApprovals    GatePass[]          @relation("GatePassApprover")

  // Phase 5 relations
  violations            Violation[]         @relation("ViolationStudent")
  violationsResolved    Violation[]         @relation("ViolationResolver")
  notificationsReceived Notification[]      @relation("NotificationRecipient")

  // Phase 6 relations
  hostelRegistrations   HostelRegistration[] @relation("RegistrationStudent")
  registrationsReviewed HostelRegistration[] @relation("RegistrationReviewer")
  registrationFees      RegistrationFee[]    @relation("FeeRecordedBy")

  // Phase 7: Attendance relations
  attendanceRecords      DailyAttendance[]    @relation("AttendanceStudent")
  attendanceMarked       DailyAttendance[]    @relation("AttendanceMarker")
  sessionsCreated        AttendanceSession[]  @relation("SessionCreator")
  studentDevices         StudentDevice[]      @relation("UserDevices")
  devicesDeactivated     StudentDevice[]      @relation("DeviceDeactivator")
  deviceChangeRequests   DeviceChangeRequest[] @relation("DeviceRequester")
  deviceChangesReviewed  DeviceChangeRequest[] @relation("DeviceReviewer")

  // Phase 8: Mess Management relations
  mealScans              MealScan[]           @relation("MealScanStudent")
  mealScansAsStaff       MealScan[]           @relation("MealScanStaff")
  mealFeedback           MealFeedback[]       @relation("MealFeedbackStudent")
  messRebates            MessRebate[]         @relation("RebateStudent")
  messRebatesReviewed    MessRebate[]         @relation("RebateReviewer")
  messMenusCreated       MessMenu[]           @relation("MessMenuCreator")

  // Auth - Password Reset
  passwordResetTokens   PasswordResetToken[]

  @@index([email])
  @@index([mobile])
  @@index([usn])
  @@index([status])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

// ---------------------------------------------------------------------------
// Roles & Permissions (RBAC)
// ---------------------------------------------------------------------------

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  displayName String   @map("display_name") @db.VarChar(100)
  description String?  @db.VarChar(500)
  isSystem    Boolean  @default(false) @map("is_system") // System roles cannot be deleted
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100) // e.g., USER_CREATE
  module      String   @db.VarChar(50)          // e.g., users, hostel, finance
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  hostelId  String?   @map("hostel_id") @db.Uuid // Scoped role (null = global)
  grantedAt DateTime  @default(now()) @map("granted_at")
  grantedBy String?   @map("granted_by") @db.Uuid
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  hostel Hostel? @relation(fields: [hostelId], references: [id])

  @@unique([userId, roleId, hostelId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ---------------------------------------------------------------------------
// Refresh Tokens
// ---------------------------------------------------------------------------

model RefreshToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash") @db.VarChar(255)
  deviceInfo  String?   @map("device_info") @db.VarChar(500)
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Password Reset Tokens
// ---------------------------------------------------------------------------

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Audit Logs
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100) // e.g., LOGIN, USER_CREATE
  resource   String   @db.VarChar(100) // e.g., auth, users
  resourceId String?  @map("resource_id") @db.VarChar(255)
  details    Json?    // Additional context
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation("AuditUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Phase 2: Hostel Management
// ---------------------------------------------------------------------------

model Hostel {
  id          String       @id @default(uuid()) @db.Uuid
  code        String       @unique @db.VarChar(10)
  name        String       @db.VarChar(200)
  type        HostelType
  address     String?      @db.VarChar(500)
  totalBlocks Int          @default(1) @map("total_blocks")
  contactNo   String?      @map("contact_no") @db.VarChar(20)
  email       String?      @db.VarChar(255)
  status      HostelStatus @default(ACTIVE)
  capacity    Int          @default(0)
  description String?      @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  rooms     Room[]
  userRoles UserRole[]

  // Phase 3: Building link
  buildingId String?  @map("building_id") @db.Uuid
  building   Building? @relation(fields: [buildingId], references: [id])

  // Phase 4 relations
  leaveRequests LeaveRequest[]
  complaints    Complaint[]
  notices       Notice[]      @relation("NoticeHostel")

  // Phase 6 relations
  hostelRegistrations HostelRegistration[]

  // Phase 7: Attendance relations
  attendanceSessions  AttendanceSession[]

  // Phase 8: Mess Management relations
  messMenus      MessMenu[]      @relation("MessMenuHostel")
  mealScans      MealScan[]      @relation("MealScanHostel")
  mealFeedback   MealFeedback[]  @relation("MealFeedbackHostel")
  messRebates    MessRebate[]    @relation("RebateHostel")

  @@index([type])
  @@index([status])
  @@map("hostels")
}

enum HostelType {
  BOYS
  GIRLS
  CO_ED
}

enum HostelStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
}

// ---------------------------------------------------------------------------
// Phase 2: Room Management
// ---------------------------------------------------------------------------

model Room {
  id        String     @id @default(uuid()) @db.Uuid
  hostelId  String     @map("hostel_id") @db.Uuid
  roomNo    String     @map("room_no") @db.VarChar(20)
  floor     Int        @default(0)
  block     String?    @db.VarChar(10) // Block A, B, C etc.
  type      RoomType   @default(DOUBLE)
  capacity  Int        @default(2)
  status    RoomStatus @default(AVAILABLE)
  amenities String[]   @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  hostel Hostel @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  beds   Bed[]

  @@unique([hostelId, roomNo])
  @@index([hostelId])
  @@index([floor])
  @@index([status])
  @@index([type])
  @@map("rooms")
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
  DORMITORY
}

enum RoomStatus {
  AVAILABLE
  FULL
  UNDER_MAINTENANCE
  CLOSED
}

// ---------------------------------------------------------------------------
// Phase 2: Bed Management
// ---------------------------------------------------------------------------

model Bed {
  id        String    @id @default(uuid()) @db.Uuid
  roomId    String    @map("room_id") @db.Uuid
  bedNo     String    @map("bed_no") @db.VarChar(10)
  status    BedStatus @default(VACANT)
  studentId String?   @map("student_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  room    Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student User? @relation("BedStudent", fields: [studentId], references: [id])
  assignments BedAssignment[]

  @@unique([roomId, bedNo])
  @@index([roomId])
  @@index([studentId])
  @@index([status])
  @@map("beds")
}

enum BedStatus {
  VACANT
  OCCUPIED
  RESERVED
  UNDER_MAINTENANCE
}

// ---------------------------------------------------------------------------
// Phase 3: Building Management
// ---------------------------------------------------------------------------

model Building {
  id          String         @id @default(uuid()) @db.Uuid
  code        String         @unique @db.VarChar(20)
  name        String         @db.VarChar(200)
  location    String?        @db.VarChar(500)   // City / campus area
  address     String?        @db.VarChar(500)
  contactNo   String?        @map("contact_no") @db.VarChar(20)
  email       String?        @db.VarChar(255)
  totalFloors Int            @default(1) @map("total_floors")
  status      BuildingStatus @default(ACTIVE)
  description String?        @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  hostels  Hostel[]
  policies BuildingPolicy[]
  notices  Notice[]  @relation("NoticeBuilding")
  policySnapshots PolicySnapshot[]

  @@index([status])
  @@map("buildings")
}

enum BuildingStatus {
  ACTIVE
  INACTIVE
  UNDER_CONSTRUCTION
  UNDER_MAINTENANCE
}

// ---------------------------------------------------------------------------
// Phase 3: Policy Engine
// ---------------------------------------------------------------------------

model BuildingPolicy {
  id         String     @id @default(uuid()) @db.Uuid
  buildingId String     @map("building_id") @db.Uuid
  version    Int        @default(1)
  isActive   Boolean    @default(true) @map("is_active")

  // Curfew settings
  weekdayCurfew  String   @default("22:00") @map("weekday_curfew") @db.VarChar(5) // HH:mm
  weekendCurfew  String   @default("23:00") @map("weekend_curfew") @db.VarChar(5)
  toleranceMin   Int      @default(15) @map("tolerance_min")

  // Leave settings
  parentApprovalRequired Boolean @default(true) @map("parent_approval_required")
  maxLeaveDays           Int     @default(7) @map("max_leave_days")

  // Escalation settings
  wardenEscalationMin   Int @default(30) @map("warden_escalation_min")  // Minutes late before escalation
  repeatedViolationThreshold Int @default(3) @map("repeated_violation_threshold")

  // Notification settings
  notifyParentOnExit    Boolean @default(true) @map("notify_parent_on_exit")
  notifyParentOnEntry   Boolean @default(true) @map("notify_parent_on_entry")
  notifyParentOnLate    Boolean @default(true) @map("notify_parent_on_late")
  notifyWardenOnLate    Boolean @default(true) @map("notify_warden_on_late")

  // Override notes
  overrideNotes String? @map("override_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by") @db.Uuid

  // Violation window
  violationWindow Int @default(30) @map("violation_window") // Rolling days for repeated count

  // Relations
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  policySnapshots PolicySnapshot[]

  @@unique([buildingId, version])
  @@index([buildingId, isActive])
  @@map("building_policies")
}

// ---------------------------------------------------------------------------
// Phase 3: Student Profile Extension
// ---------------------------------------------------------------------------

model StudentProfile {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  bloodGroup  String?   @map("blood_group") @db.VarChar(5)  // A+, B-, O+, etc.
  gender      String?   @db.VarChar(10)
  department  String?   @db.VarChar(100)
  course      String?   @db.VarChar(100)
  year        Int?      // Academic year 1,2,3,4
  semester    Int?
  admissionDate DateTime? @map("admission_date") @db.Date
  emergencyContact String? @map("emergency_contact") @db.VarChar(20)
  permanentAddress String? @map("permanent_address") @db.Text
  medicalConditions String? @map("medical_conditions") @db.Text

  // Phase 6: Extended fields from BMS admission form
  fatherName          String?   @map("father_name") @db.VarChar(200)
  motherName          String?   @map("mother_name") @db.VarChar(200)
  fatherOccupation    String?   @map("father_occupation") @db.VarChar(200)
  motherOccupation    String?   @map("mother_occupation") @db.VarChar(200)
  motherTongue        String?   @map("mother_tongue") @db.VarChar(50)
  nationality         String?   @db.VarChar(50)
  religion            String?   @db.VarChar(50)
  category            String?   @db.VarChar(30) // SC, ST, OBC, GM, etc.
  pucPercentage       Float?    @map("puc_percentage")  // PCM percentage
  admissionMode       AdmissionMode? @map("admission_mode")
  communicationAddress String?  @map("communication_address") @db.Text

  // Parent contacts
  fatherEmail         String?   @map("father_email") @db.VarChar(255)
  fatherMobile        String?   @map("father_mobile") @db.VarChar(20)
  fatherLandline      String?   @map("father_landline") @db.VarChar(20)
  motherEmail         String?   @map("mother_email") @db.VarChar(255)
  motherMobile        String?   @map("mother_mobile") @db.VarChar(20)
  motherLandline      String?   @map("mother_landline") @db.VarChar(20)

  // Local guardian (for emergency / outstation students)
  localGuardianName    String?  @map("local_guardian_name") @db.VarChar(200)
  localGuardianAddress String?  @map("local_guardian_address") @db.Text
  localGuardianMobile  String?  @map("local_guardian_mobile") @db.VarChar(20)
  localGuardianLandline String? @map("local_guardian_landline") @db.VarChar(20)
  localGuardianEmail   String?  @map("local_guardian_email") @db.VarChar(255)

  // International student details
  passportNo           String?  @map("passport_no") @db.VarChar(50)
  visaDetails          String?  @map("visa_details") @db.Text
  residentialPermit    String?  @map("residential_permit") @db.Text

  // Photo
  photoUrl             String?  @map("photo_url") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

// ---------------------------------------------------------------------------
// Phase 3: Guardian / Parent Linkage
// ---------------------------------------------------------------------------

model GuardianLink {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String   @map("student_id") @db.Uuid   // The student (ward)
  guardianId String   @map("guardian_id") @db.Uuid   // The parent/guardian user
  relation   String   @db.VarChar(50)                // Father, Mother, Guardian, etc.
  isPrimary  Boolean  @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student  User @relation("WardUser", fields: [studentId], references: [id], onDelete: Cascade)
  guardian User @relation("GuardianUser", fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([studentId])
  @@index([guardianId])
  @@map("guardian_links")
}

// ---------------------------------------------------------------------------
// Phase 3: Bed Assignment / Allotment History
// ---------------------------------------------------------------------------

model BedAssignment {
  id         String           @id @default(uuid()) @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  bedId      String           @map("bed_id") @db.Uuid
  status         AssignmentStatus @default(ACTIVE)
  presenceStatus PresenceStatus   @default(IN_HOSTEL) @map("presence_status")

  assignedAt  DateTime  @default(now()) @map("assigned_at")
  vacatedAt   DateTime? @map("vacated_at")
  assignedById String?  @map("assigned_by_id") @db.Uuid
  reason      String?   @db.VarChar(500) // Reason for assignment/transfer/vacate
  notes       String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student    User @relation("AssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  bed        Bed  @relation(fields: [bedId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("AssignmentAssignedBy", fields: [assignedById], references: [id])

  @@index([studentId])
  @@index([bedId])
  @@index([status])
  @@index([assignedAt])
  @@map("bed_assignments")
}

enum AssignmentStatus {
  ACTIVE
  VACATED
  TRANSFERRED
  EXPIRED
}

// ---------------------------------------------------------------------------
// Phase 4: Leave Management
// ---------------------------------------------------------------------------

model LeaveRequest {
  id        String       @id @default(uuid()) @db.Uuid
  studentId String       @map("student_id") @db.Uuid
  hostelId  String       @map("hostel_id") @db.Uuid
  type      LeaveType
  fromDate  DateTime     @map("from_date") @db.Date
  toDate    DateTime     @map("to_date") @db.Date
  reason    String       @db.Text
  proofUrl  String?      @map("proof_url") @db.VarChar(500)
  status    LeaveStatus  @default(PENDING)

  parentApprovalAt  DateTime? @map("parent_approval_at")
  wardenApprovalAt  DateTime? @map("warden_approval_at")
  rejectedAt        DateTime? @map("rejected_at")
  rejectionReason   String?   @map("rejection_reason") @db.Text
  wardenId          String?   @map("warden_id") @db.Uuid
  parentId          String?   @map("parent_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student User   @relation("LeaveStudent", fields: [studentId], references: [id], onDelete: Cascade)
  hostel  Hostel @relation(fields: [hostelId], references: [id])
  warden  User?  @relation("LeaveWarden", fields: [wardenId], references: [id])
  parent  User?  @relation("LeaveParent", fields: [parentId], references: [id])
  gateEntries          GateEntry[]       @relation("GateLeave")
  notifications        Notification[]    @relation("LeaveNotifications")
  attendanceRecords    DailyAttendance[] @relation("AttendanceLeave")

  // Phase 8: Mess rebates linked to leave
  messRebates          MessRebate[]      @relation("RebateLeave")

  @@index([studentId])
  @@index([hostelId])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("leave_requests")
}

enum LeaveType {
  HOME
  MEDICAL
  EMERGENCY
  OTHER
}

enum LeaveStatus {
  PENDING
  PARENT_APPROVED
  PARENT_REJECTED
  WARDEN_APPROVED
  REJECTED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Phase 4: Complaints
// ---------------------------------------------------------------------------

model Complaint {
  id           String           @id @default(uuid()) @db.Uuid
  studentId    String           @map("student_id") @db.Uuid
  hostelId     String           @map("hostel_id") @db.Uuid
  category     ComplaintCategory
  subject      String           @db.VarChar(200)
  description  String           @db.Text
  priority     ComplaintPriority @default(MEDIUM)
  status       ComplaintStatus   @default(OPEN)
  isAnonymous  Boolean           @default(false) @map("is_anonymous")

  assignedToId String?   @map("assigned_to_id") @db.Uuid
  resolvedAt   DateTime? @map("resolved_at")
  resolution   String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student    User              @relation("ComplaintStudent", fields: [studentId], references: [id], onDelete: Cascade)
  hostel     Hostel            @relation(fields: [hostelId], references: [id])
  assignedTo User?             @relation("ComplaintAssignedTo", fields: [assignedToId], references: [id])
  comments   ComplaintComment[]

  @@index([studentId])
  @@index([hostelId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@map("complaints")
}

model ComplaintComment {
  id          String   @id @default(uuid()) @db.Uuid
  complaintId String   @map("complaint_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  message     String   @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("complaint_comments")
}

enum ComplaintCategory {
  MAINTENANCE
  ELECTRICAL
  PLUMBING
  MESS
  HYGIENE
  SECURITY
  OTHER
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

// ---------------------------------------------------------------------------
// Phase 4: Notices / Announcements
// ---------------------------------------------------------------------------

model Notice {
  id              String        @id @default(uuid()) @db.Uuid
  title           String        @db.VarChar(200)
  body            String        @db.Text
  priority        NoticePriority @default(INFO)
  scope           NoticeScope    @default(ALL)
  targetBuildingId String?      @map("target_building_id") @db.Uuid
  targetHostelId   String?      @map("target_hostel_id") @db.Uuid
  publishedById   String        @map("published_by_id") @db.Uuid
  publishedAt     DateTime      @default(now()) @map("published_at")
  expiresAt       DateTime?     @map("expires_at")
  isActive        Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  publishedBy    User              @relation("NoticePublisher", fields: [publishedById], references: [id])
  targetBuilding Building?         @relation("NoticeBuilding", fields: [targetBuildingId], references: [id])
  targetHostel   Hostel?           @relation("NoticeHostel", fields: [targetHostelId], references: [id])
  recipients     NoticeRecipient[]

  @@index([scope])
  @@index([publishedAt])
  @@index([isActive])
  @@map("notices")
}

model NoticeRecipient {
  id       String    @id @default(uuid()) @db.Uuid
  noticeId String    @map("notice_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  readAt   DateTime? @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
  @@index([noticeId])
  @@index([userId])
  @@map("notice_recipients")
}

enum NoticePriority {
  INFO
  WARNING
  URGENT
}

enum NoticeScope {
  ALL
  BUILDING
  HOSTEL
}

// ---------------------------------------------------------------------------
// Phase 4: Gate Management
// ---------------------------------------------------------------------------

model GateEntry {
  id           String    @id @default(uuid()) @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  type         GateEntryType
  gateNo       String    @map("gate_no") @db.VarChar(20)
  scannedById  String?   @map("scanned_by_id") @db.Uuid
  timestamp    DateTime  @default(now())
  isLateEntry  Boolean   @default(false) @map("is_late_entry")
  lateMinutes  Int?      @map("late_minutes")
  linkedLeaveId String?  @map("linked_leave_id") @db.Uuid
  notes        String?   @db.Text

  // Phase 5: policy snapshot + violation links
  policySnapshotId String? @map("policy_snapshot_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  student        User            @relation("GateStudent", fields: [studentId], references: [id], onDelete: Cascade)
  scannedBy      User?           @relation("GateScanner", fields: [scannedById], references: [id])
  linkedLeave    LeaveRequest?   @relation("GateLeave", fields: [linkedLeaveId], references: [id])
  policySnapshot PolicySnapshot? @relation(fields: [policySnapshotId], references: [id])
  violations     Violation[]
  notifications  Notification[]  @relation("EntryNotifications")

  @@index([studentId])
  @@index([timestamp])
  @@index([isLateEntry])
  @@index([type])
  @@map("gate_entries")
}

model GatePass {
  id           String        @id @default(uuid()) @db.Uuid
  studentId    String        @map("student_id") @db.Uuid
  purpose      String        @db.VarChar(500)
  visitorName  String?       @map("visitor_name") @db.VarChar(200)
  visitorPhone String?       @map("visitor_phone") @db.VarChar(20)
  validFrom    DateTime      @map("valid_from")
  validTo      DateTime      @map("valid_to")
  status       GatePassStatus @default(ACTIVE)
  approvedById String?       @map("approved_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student    User  @relation("GatePassStudent", fields: [studentId], references: [id], onDelete: Cascade)
  approvedBy User? @relation("GatePassApprover", fields: [approvedById], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([validFrom, validTo])
  @@map("gate_passes")
}

enum GateEntryType {
  IN
  OUT
}

enum GatePassStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Phase 5: Policy Snapshots
// ---------------------------------------------------------------------------

model PolicySnapshot {
  id                  String   @id @default(uuid()) @db.Uuid
  buildingId          String   @map("building_id") @db.Uuid
  policyId            String   @map("policy_id") @db.Uuid
  policyVersion       Int      @map("policy_version")
  curfewTimeUsed      String   @map("curfew_time_used") @db.VarChar(5)
  toleranceMinUsed    Int      @map("tolerance_min_used")
  leaveDeadlineUsed   DateTime? @map("leave_deadline_used")
  escalationRuleMin   Int      @map("escalation_rule_min")
  repeatedThreshold   Int      @map("repeated_threshold")
  violationWindow     Int      @map("violation_window")
  notifyParentOnExit  Boolean  @map("notify_parent_on_exit")
  notifyParentOnEntry Boolean  @map("notify_parent_on_entry")
  notifyParentOnLate  Boolean  @map("notify_parent_on_late")
  notifyWardenOnLate  Boolean  @map("notify_warden_on_late")
  snapshotData        Json?    @map("snapshot_data")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  building    Building       @relation(fields: [buildingId], references: [id])
  policy      BuildingPolicy @relation(fields: [policyId], references: [id])
  gateEntries GateEntry[]
  violations  Violation[]

  @@index([buildingId])
  @@index([policyId])
  @@map("policy_snapshots")
}

// ---------------------------------------------------------------------------
// Phase 5: Violations
// ---------------------------------------------------------------------------

model Violation {
  id                      String            @id @default(uuid()) @db.Uuid
  studentId               String            @map("student_id") @db.Uuid
  gateEntryId             String            @map("gate_entry_id") @db.Uuid
  policySnapshotId        String            @map("policy_snapshot_id") @db.Uuid
  type                    ViolationType
  requestedOrApprovedTime DateTime          @map("requested_or_approved_time")
  actualTime              DateTime          @map("actual_time")
  violatedByMinutes       Int               @map("violated_by_minutes")
  reason                  String            @db.Text
  repeatedCountSnapshot   Int               @map("repeated_count_snapshot")
  escalationState         EscalationState   @default(NONE) @map("escalation_state")
  notificationState       NotificationState @default(PENDING) @map("notification_state")
  resolvedAt              DateTime?         @map("resolved_at")
  resolvedById            String?           @map("resolved_by_id") @db.Uuid
  resolvedNotes           String?           @map("resolved_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student        User           @relation("ViolationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  gateEntry      GateEntry      @relation(fields: [gateEntryId], references: [id])
  policySnapshot PolicySnapshot @relation(fields: [policySnapshotId], references: [id])
  resolvedBy     User?          @relation("ViolationResolver", fields: [resolvedById], references: [id])
  notifications  Notification[] @relation("ViolationNotifications")

  @@index([studentId])
  @@index([type])
  @@index([escalationState])
  @@index([createdAt])
  @@map("violations")
}

enum ViolationType {
  LATE_ENTRY
  OVERSTAY
  EARLY_EXIT
}

enum EscalationState {
  NONE
  WARNED
  ESCALATED
  RESOLVED
}

enum NotificationState {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// ---------------------------------------------------------------------------
// Phase 5: Notifications
// ---------------------------------------------------------------------------

model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  recipientId String              @map("recipient_id") @db.Uuid
  channel     NotificationChannel @default(IN_APP)
  title       String              @db.VarChar(200)
  message     String              @db.Text
  violationId    String?             @map("violation_id") @db.Uuid
  gateEntryId    String?             @map("gate_entry_id") @db.Uuid
  leaveRequestId String?             @map("leave_request_id") @db.Uuid
  state       NotificationState   @default(PENDING)
  readAt      DateTime?           @map("read_at")
  sentAt      DateTime?           @map("sent_at")
  failReason  String?             @map("fail_reason") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  recipient User       @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  violation    Violation?    @relation("ViolationNotifications", fields: [violationId], references: [id])
  gateEntry    GateEntry?    @relation("EntryNotifications", fields: [gateEntryId], references: [id])
  leaveRequest LeaveRequest? @relation("LeaveNotifications", fields: [leaveRequestId], references: [id])

  @@index([recipientId, readAt])
  @@index([state])
  @@index([createdAt])
  @@map("notifications")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
  WHATSAPP
}

// ---------------------------------------------------------------------------
// Phase 6: Student Registration / Hostel Admission
// ---------------------------------------------------------------------------

enum AdmissionMode {
  CET
  COMEDK
  MANAGEMENT
  NRI
  NRI_SPONSORED
  PIO
  FOREIGN_NATIONAL
  OTHER
}

enum RegistrationStatus {
  DRAFT                // Student started but hasn't submitted
  SUBMITTED            // Student submitted the form
  UNDER_REVIEW         // Admin/Warden is reviewing
  DOCUMENTS_PENDING    // Documents incomplete, needs resubmission
  APPROVED             // Application approved, pending allotment
  ALLOTTED             // Room/bed allotted, registration complete
  REJECTED             // Application rejected
  CANCELLED            // Student cancelled the application
  WAITLISTED           // Capacity full, student on waitlist
}

model HostelRegistration {
  id              String              @id @default(uuid()) @db.Uuid
  applicationNo   String              @unique @map("application_no") @db.VarChar(20) // Sequential: IH-2026-0001
  studentId       String              @map("student_id") @db.Uuid
  academicYear    String              @map("academic_year") @db.VarChar(9) // e.g., 2025-2026
  hostelId        String?             @map("hostel_id") @db.Uuid      // Preferred hostel
  status          RegistrationStatus  @default(DRAFT)

  // Snapshot of student details at registration time (for historical record)
  studentSnapshot Json?               @map("student_snapshot")

  // Room/Mess preferences
  roomTypePreference String?          @map("room_type_preference") @db.VarChar(20) // SINGLE, DOUBLE, TRIPLE
  messType           String?          @map("mess_type") @db.VarChar(10)            // VEG, NON_VEG
  previousHostelHistory String?       @map("previous_hostel_history") @db.Text

  // Declarations (digital signatures)
  hosteliteDeclarationAccepted   Boolean   @default(false) @map("hostelite_declaration_accepted")
  hosteliteDeclarationAt         DateTime? @map("hostelite_declaration_at")
  hosteliteDeclarationDocUrl     String?   @map("hostelite_declaration_doc_url") @db.Text
  antiRaggingStudentAccepted     Boolean   @default(false) @map("anti_ragging_student_accepted")
  antiRaggingStudentAt           DateTime? @map("anti_ragging_student_at")
  antiRaggingStudentDocUrl       String?   @map("anti_ragging_student_doc_url") @db.Text
  antiRaggingParentAccepted      Boolean   @default(false) @map("anti_ragging_parent_accepted")
  antiRaggingParentAt            DateTime? @map("anti_ragging_parent_at")
  antiRaggingParentDocUrl        String?   @map("anti_ragging_parent_doc_url") @db.Text
  hostelAgreementAccepted        Boolean   @default(false) @map("hostel_agreement_accepted")
  hostelAgreementAt              DateTime? @map("hostel_agreement_at")
  hostelAgreementDocUrl          String?   @map("hostel_agreement_doc_url") @db.Text
  raggingPreventionAccepted      Boolean   @default(false) @map("ragging_prevention_accepted")
  raggingPreventionAt            DateTime? @map("ragging_prevention_at")
  raggingPreventionDocUrl        String?   @map("ragging_prevention_doc_url") @db.Text

  // Admin review
  reviewedById     String?    @map("reviewed_by_id") @db.Uuid
  reviewedAt       DateTime?  @map("reviewed_at")
  reviewNotes      String?    @map("review_notes") @db.Text
  rejectionReason  String?    @map("rejection_reason") @db.Text

  // Office use (generated after approval)
  hostelIdNo       String?    @map("hostel_id_no") @db.VarChar(30) // Hostel ID number
  messRollNo       String?    @map("mess_roll_no") @db.VarChar(30) // Mess Roll number
  dateOfOccupation DateTime?  @map("date_of_occupation") @db.Date

  // Submitted / completed timestamps
  submittedAt      DateTime?  @map("submitted_at")
  completedAt      DateTime?  @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student    User      @relation("RegistrationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  hostel     Hostel?   @relation(fields: [hostelId], references: [id])
  reviewedBy User?     @relation("RegistrationReviewer", fields: [reviewedById], references: [id])
  fees       RegistrationFee[]

  @@index([studentId])
  @@index([status])
  @@index([academicYear])
  @@index([applicationNo])
  @@map("hostel_registrations")
}

model RegistrationFee {
  id              String   @id @default(uuid()) @db.Uuid
  registrationId  String   @map("registration_id") @db.Uuid
  feeType         FeeType  @map("fee_type")
  amount          Float
  receiptNo       String?  @map("receipt_no") @db.VarChar(50)
  paidAt          DateTime? @map("paid_at") @db.Date
  recordedById    String?  @map("recorded_by_id") @db.Uuid
  notes           String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  registration HostelRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  recordedBy   User?              @relation("FeeRecordedBy", fields: [recordedById], references: [id])

  @@index([registrationId])
  @@index([feeType])
  @@map("registration_fees")
}

enum FeeType {
  HOSTEL_FEE
  MESS_FEE
  CAUTION_DEPOSIT
  OTHER
}

// ===========================================================================
// Phase 7: Attendance Tracking (Anti-Proxy, Enterprise-Grade)
// ===========================================================================

enum AttendanceStatus {
  PRESENT
  ABSENT
  ON_LEAVE
  LATE
  UNKNOWN
}

enum AttendanceSource {
  GATE
  QR_SCAN
  ROLL_CALL
  SYSTEM
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PresenceStatus {
  IN_HOSTEL
  OUT_CAMPUS
  ON_LEAVE
}

enum DeviceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ---------------------------------------------------------------------------
// Daily Attendance — one row per student per day
// ---------------------------------------------------------------------------

model DailyAttendance {
  id         String           @id @default(uuid()) @db.Uuid
  studentId  String           @map("student_id") @db.Uuid
  date       DateTime         @db.Date
  status     AttendanceStatus @default(UNKNOWN)
  firstIn    DateTime?        @map("first_in")
  lastOut    DateTime?        @map("last_out")
  lastIn     DateTime?        @map("last_in")
  isOnLeave  Boolean          @default(false) @map("is_on_leave")
  leaveId    String?          @map("leave_id") @db.Uuid
  sessionId  String?          @map("session_id") @db.Uuid
  markedBy   String?          @map("marked_by") @db.Uuid
  source     AttendanceSource @default(GATE)
  gpsLat     Float?           @map("gps_lat")
  gpsLng     Float?           @map("gps_lng")
  deviceId   String?          @map("device_id") @db.Uuid
  notes      String?          @db.Text
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  // Relations
  student    User              @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  leave      LeaveRequest?     @relation("AttendanceLeave", fields: [leaveId], references: [id])
  session    AttendanceSession? @relation(fields: [sessionId], references: [id])
  marker     User?             @relation("AttendanceMarker", fields: [markedBy], references: [id])

  @@unique([studentId, date])
  @@index([date])
  @@index([status])
  @@map("daily_attendance")
}

// ---------------------------------------------------------------------------
// Attendance Session — warden-initiated roll-call
// ---------------------------------------------------------------------------

model AttendanceSession {
  id            String        @id @default(uuid()) @db.Uuid
  hostelId      String        @map("hostel_id") @db.Uuid
  createdById   String        @map("created_by_id") @db.Uuid
  sessionSecret String        @map("session_secret") @db.VarChar(64)
  title         String?       @db.VarChar(200)
  startsAt      DateTime      @map("starts_at")
  expiresAt     DateTime      @map("expires_at")
  status        SessionStatus @default(ACTIVE)
  gpsLat        Float         @map("gps_lat")
  gpsLng        Float         @map("gps_lng")
  gpsRadiusM    Int           @default(150) @map("gps_radius_m")
  totalStudents Int           @default(0) @map("total_students")
  presentCount  Int           @default(0) @map("present_count")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  hostel      Hostel             @relation(fields: [hostelId], references: [id])
  createdBy   User               @relation("SessionCreator", fields: [createdById], references: [id])
  attendance  DailyAttendance[]

  @@index([hostelId, status])
  @@index([expiresAt])
  @@map("attendance_sessions")
}

// ---------------------------------------------------------------------------
// Student Device — fingerprint binding for anti-proxy
// ---------------------------------------------------------------------------

model StudentDevice {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  fingerprint     String       @db.VarChar(255)
  deviceName      String?      @map("device_name") @db.VarChar(200)
  platform        String?      @db.VarChar(50)
  isActive        Boolean      @default(true) @map("is_active")
  registeredAt    DateTime     @default(now()) @map("registered_at")
  deactivatedAt   DateTime?    @map("deactivated_at")
  deactivatedById String?      @map("deactivated_by_id") @db.Uuid

  // Relations
  user          User  @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  deactivatedBy User? @relation("DeviceDeactivator", fields: [deactivatedById], references: [id])

  @@index([userId, isActive])
  @@index([fingerprint])
  @@map("student_devices")
}

// ---------------------------------------------------------------------------
// Device Change Request — warden-approved re-bind
// ---------------------------------------------------------------------------

model DeviceChangeRequest {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  newFingerprint  String              @map("new_fingerprint") @db.VarChar(255)
  newDeviceName   String?             @map("new_device_name") @db.VarChar(200)
  newPlatform     String?             @map("new_platform") @db.VarChar(50)
  reason          String?             @db.Text
  status          DeviceRequestStatus @default(PENDING)
  reviewedById    String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?           @map("reviewed_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  // Relations
  user       User  @relation("DeviceRequester", fields: [userId], references: [id])
  reviewedBy User? @relation("DeviceReviewer", fields: [reviewedById], references: [id])

  @@index([userId, status])
  @@map("device_change_requests")
}

// ===========================================================================
// Phase 8: Mess Management
// ===========================================================================

enum MealType {
  BREAKFAST
  LUNCH
  SNACKS
  DINNER
}

enum MessType {
  VEG
  NON_VEG
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum MealScanStatus {
  SCANNED
  CANCELLED
}

enum RebateStatus {
  PENDING
  APPROVED
  REJECTED
  CREDITED
}

enum MenuStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Mess Menu — Weekly rotating menu template
// ---------------------------------------------------------------------------

model MessMenu {
  id            String     @id @default(uuid()) @db.Uuid
  hostelId      String     @map("hostel_id") @db.Uuid
  name          String     @db.VarChar(200)
  messType      MessType   @map("mess_type")
  status        MenuStatus @default(DRAFT)
  effectiveFrom DateTime   @map("effective_from") @db.Date
  effectiveTo   DateTime?  @map("effective_to") @db.Date
  createdById   String     @map("created_by_id") @db.Uuid
  notes         String?    @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  hostel    Hostel         @relation("MessMenuHostel", fields: [hostelId], references: [id])
  createdBy User           @relation("MessMenuCreator", fields: [createdById], references: [id])
  items     MessMenuItem[]

  @@unique([hostelId, messType, status], map: "uq_active_menu")
  @@index([hostelId])
  @@index([status])
  @@index([effectiveFrom])
  @@map("mess_menus")
}

// ---------------------------------------------------------------------------
// Mess Menu Item — Individual dish per day+meal slot
// ---------------------------------------------------------------------------

model MessMenuItem {
  id          String    @id @default(uuid()) @db.Uuid
  menuId      String    @map("menu_id") @db.Uuid
  day         DayOfWeek
  mealType    MealType  @map("meal_type")
  items       String    @db.Text
  specialNote String?   @map("special_note") @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  menu MessMenu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([menuId, day, mealType], map: "uq_menu_day_meal")
  @@index([menuId])
  @@map("mess_menu_items")
}

// ---------------------------------------------------------------------------
// Meal Scan — Per-student per-meal attendance log
// ---------------------------------------------------------------------------

model MealScan {
  id                String         @id @default(uuid()) @db.Uuid
  studentId         String         @map("student_id") @db.Uuid
  hostelId          String         @map("hostel_id") @db.Uuid
  date              DateTime       @db.Date
  mealType          MealType       @map("meal_type")
  scannedAt         DateTime       @default(now()) @map("scanned_at")
  scannedById       String         @map("scanned_by_id") @db.Uuid
  status            MealScanStatus @default(SCANNED)
  isGuest           Boolean        @default(false) @map("is_guest")
  guestName         String?        @map("guest_name") @db.VarChar(200)
  guestCount        Int            @default(1) @map("guest_count")
  notes             String?        @db.VarChar(500)
  deviceFingerprint String?        @map("device_fingerprint") @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student   User   @relation("MealScanStudent", fields: [studentId], references: [id], onDelete: Cascade)
  hostel    Hostel @relation("MealScanHostel", fields: [hostelId], references: [id])
  scannedBy User   @relation("MealScanStaff", fields: [scannedById], references: [id])

  @@unique([studentId, date, mealType], map: "uq_student_meal_per_day")
  @@index([studentId])
  @@index([hostelId])
  @@index([date])
  @@index([mealType])
  @@index([scannedAt])
  @@map("meal_scans")
}

// ---------------------------------------------------------------------------
// Meal Feedback — Student rates a meal (1–5 stars)
// ---------------------------------------------------------------------------

model MealFeedback {
  id          String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  hostelId    String   @map("hostel_id") @db.Uuid
  date        DateTime @db.Date
  mealType    MealType @map("meal_type")
  rating      Int
  comment     String?  @db.Text
  isAnonymous Boolean  @default(false) @map("is_anonymous")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  student User   @relation("MealFeedbackStudent", fields: [studentId], references: [id], onDelete: Cascade)
  hostel  Hostel @relation("MealFeedbackHostel", fields: [hostelId], references: [id])

  @@unique([studentId, date, mealType], map: "uq_feedback_per_meal")
  @@index([hostelId])
  @@index([date])
  @@index([rating])
  @@map("meal_feedback")
}

// ---------------------------------------------------------------------------
// Mess Rebate — Fee refund for absent meals
// ---------------------------------------------------------------------------

model MessRebate {
  id           String       @id @default(uuid()) @db.Uuid
  studentId    String       @map("student_id") @db.Uuid
  hostelId     String       @map("hostel_id") @db.Uuid
  fromDate     DateTime     @map("from_date") @db.Date
  toDate       DateTime     @map("to_date") @db.Date
  totalMeals   Int          @map("total_meals")
  amount       Float?
  status       RebateStatus @default(PENDING)
  reason       String       @db.Text
  leaveId      String?      @map("leave_id") @db.Uuid
  reviewedById String?      @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime?    @map("reviewed_at")
  reviewNotes  String?      @map("review_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student    User          @relation("RebateStudent", fields: [studentId], references: [id], onDelete: Cascade)
  hostel     Hostel        @relation("RebateHostel", fields: [hostelId], references: [id])
  leave      LeaveRequest? @relation("RebateLeave", fields: [leaveId], references: [id])
  reviewedBy User?         @relation("RebateReviewer", fields: [reviewedById], references: [id])

  @@index([studentId])
  @@index([hostelId])
  @@index([status])
  @@index([fromDate, toDate])
  @@map("mess_rebates")
}
