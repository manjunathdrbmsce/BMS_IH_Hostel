### 2.2 Role Assign/Revoke API

#### [NEW] `apps/api/src/users/roles.controller.ts`

```typescript
@Controller('users/:userId/roles')
@UseGuards(JwtAuthGuard, RolesGuard)
export class UserRolesController {
  @Post()
  @Roles('SUPER_ADMIN', 'HOSTEL_ADMIN')
  assignRole(@Param('userId') userId, @Body() dto: AssignRoleDto) { ... }

  @Delete(':roleId')
  @Roles('SUPER_ADMIN', 'HOSTEL_ADMIN')
  revokeRole(@Param('userId') userId, @Param('roleId') roleId) { ... }

  @Get()
  @Roles('SUPER_ADMIN', 'HOSTEL_ADMIN', 'WARDEN')
  listRoles(@Param('userId') userId) { ... }
}
```

#### [NEW] `apps/api/src/users/dto/assign-role.dto.ts`

```typescript
export class AssignRoleDto {
  @IsUUID() roleId: string;
  @IsOptional() @IsUUID() hostelId?: string; // For scoped roles
}
```

#### [MODIFY] [users.module.ts](file:///d:/Apps/hostel/BMS_hostel/apps/api/src/users/users.module.ts)

- Register `UserRolesController`

#### [MODIFY] [users.service.ts](file:///d:/Apps/hostel/BMS_hostel/apps/api/src/users/users.service.ts)

- Add `assignRole()`, `revokeRole()`, `listUserRoles()` methods
