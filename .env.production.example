# =============================================================================
# BMS Hostel — Production Environment Variables
# Copy to .env.production and fill in all values
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
APP_PORT=3001
FRONTEND_URL=https://bms.hostel
API_PUBLIC_URL=https://api.bms.hostel

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=bms_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=bms_hostel
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_64_CHARS_RANDOM_STRING_HERE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Rate Limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=30

# ─── Nginx ───────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ─── Monitoring ──────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_URL=https://monitor.bms.hostel

# ─── Admin Seed ──────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@bms.hostel
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SEED_ADMIN_FIRST_NAME=System
SEED_ADMIN_LAST_NAME=Administrator

# ─── Storage (S3-compatible) ────────────────────────────────────────────────
# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_BUCKET=bms-uploads
# STORAGE_REGION=ap-south-1

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@bms.hostel

# ─── SMS (Twilio) ───────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
